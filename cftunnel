#!/usr/bin/env bash
# ============================================================================
# cftunnel - CLI to manage Cloudflare Tunnels
# https://github.com/usedilver/cloudflare-tunnel-cli
#
# Automates the full lifecycle: create, configure DNS, generate config and run.
# Works on macOS and Linux.
# ============================================================================

set -euo pipefail

VERSION="0.1.0"
CLOUDFLARED_DIR="${CLOUDFLARED_DIR:-$HOME/.cloudflared}"

# -- Colors -------------------------------------------------------------------
if [[ -t 1 ]]; then
  GREEN='\033[0;32m'  BLUE='\033[0;34m'  CYAN='\033[0;36m'
  YELLOW='\033[1;33m' RED='\033[0;31m'    BOLD='\033[1m'
  DIM='\033[2m'       NC='\033[0m'
else
  GREEN='' BLUE='' CYAN='' YELLOW='' RED='' BOLD='' DIM='' NC=''
fi

# -- Helpers ------------------------------------------------------------------
info()  { echo -e "${CYAN}[info]${NC}  $*"; }
ok()    { echo -e "${GREEN}[ok]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[warn]${NC}  $*"; }
err()   { echo -e "${RED}[error]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }

check_cloudflared() {
  command -v cloudflared &>/dev/null || die "cloudflared is not installed. Install with: brew install cloudflared"
}

# Open URL portably (macOS / Linux)
open_url() {
  local url="$1"
  if command -v open &>/dev/null; then
    open "$url" 2>/dev/null
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$url" 2>/dev/null
  fi
}

# -- Tunnel parsing -----------------------------------------------------------
# Shared arrays populated by _load_tunnels
_t_names=() _t_hosts=() _t_ports=() _t_ids=()

_load_tunnels() {
  _t_names=() _t_hosts=() _t_ports=() _t_ids=()
  local configs=()
  while IFS= read -r f; do
    configs+=("$f")
  done < <(grep -l "tunnel:" "${CLOUDFLARED_DIR}"/*.yml 2>/dev/null || true)

  if [[ ${#configs[@]} -eq 0 ]]; then
    return 1
  fi

  for file in "${configs[@]}"; do
    _t_names+=("$(basename "$file" .yml)")
    _t_hosts+=("$(grep 'hostname:' "$file" | head -n1 | awk '{print $NF}')")
    _t_ports+=("$(grep 'service: http://localhost:' "$file" | head -n1 | sed 's/.*localhost://' | tr -d '[:space:]')")
    _t_ids+=("$(grep '^tunnel:' "$file" | awk '{print $NF}')")
  done
}

_print_tunnel_row() {
  local name="$1" host="$2" port="$3" tid="$4" prefix="$5" style="$6"
  if [[ "$style" == "active" ]]; then
    printf "${prefix}${BOLD}%-20s${NC}  ${BLUE}%-35s${NC}  ${CYAN}:%-5s${NC}  ${DIM}%-36s${NC}\n" "$name" "$host" "$port" "$tid"
  else
    printf "${prefix}${DIM}%-20s  %-35s  :%-5s  %-36s${NC}\n" "$name" "$host" "$port" "$tid"
  fi
}

# -- Subcommands --------------------------------------------------------------

# cftunnel create <name> <domain> <port>
cmd_create() {
  if [[ $# -lt 3 ]]; then
    echo -e "${BOLD}Usage:${NC} cftunnel create <name> <domain> <port>"
    echo ""
    echo -e "${DIM}Example:${NC} cftunnel create my-api example.com 3000"
    echo -e "         Creates tunnel 'my-api' at my-api.example.com:3000"
    exit 1
  fi

  local name="$1" domain="$2" port="$3"
  local hostname="${name}.${domain}"

  check_cloudflared

  info "Setting up tunnel: ${BOLD}${hostname}${NC} -> localhost:${port}"
  echo ""

  # 1. Create tunnel (or reuse existing one)
  local tunnel_id=""
  local create_output
  if create_output=$(cloudflared tunnel create "$name" 2>&1); then
    tunnel_id=$(echo "$create_output" | grep -oE '[a-f0-9]{8}-([a-f0-9]{4}-){3}[a-f0-9]{12}' | head -n1 | tr -d '[:space:]')
    ok "Tunnel created: ${tunnel_id}"
  else
    if [[ "$create_output" == *"already exists"* ]]; then
      warn "Tunnel '${name}' already exists, reusing..."
      tunnel_id=$(cloudflared tunnel list -o json 2>/dev/null | grep -oE "\"id\":\"[a-f0-9-]+\"" | head -n1 | cut -d'"' -f4)
      # Fallback: parse from tunnel list text
      if [[ -z "$tunnel_id" ]]; then
        tunnel_id=$(cloudflared tunnel list 2>/dev/null | grep "$name" | awk '{print $1}' | head -n1 | tr -d '[:space:]')
      fi
    else
      die "Error creating tunnel:\n${create_output}"
    fi
  fi

  [[ -z "$tunnel_id" ]] && die "Could not obtain the Tunnel ID."

  # 2. DNS route
  info "Configuring DNS: ${hostname}..."
  if cloudflared tunnel route dns "$name" "$hostname" 2>&1; then
    ok "DNS configured"
  else
    warn "DNS route may already exist (this is normal)"
  fi

  # 3. Generate config YAML
  local config_file="${CLOUDFLARED_DIR}/${name}.yml"
  cat > "$config_file" <<EOF
tunnel: ${tunnel_id}
credentials-file: ${CLOUDFLARED_DIR}/${tunnel_id}.json

ingress:
  - hostname: ${hostname}
    service: http://localhost:${port}
  - service: http_status:404
EOF

  ok "Config generated: ${config_file}"
  echo ""
  echo -e "  ${GREEN}✔${NC} Tunnel ${BOLD}${name}${NC} ready"
  echo ""
  echo -e "  URL     ${BLUE}https://${hostname}${NC}"
  echo -e "  Port    localhost:${port}"
  echo -e "  Run     ${YELLOW}cftunnel run ${name}${NC}"
  echo ""
}

# cftunnel run [name]
cmd_run() {
  check_cloudflared

  local name="${1:-}"

  # If no name given, show interactive selector
  if [[ -z "$name" ]]; then
    cmd_run_interactive
    return
  fi

  local config_file="${CLOUDFLARED_DIR}/${name}.yml"
  [[ -f "$config_file" ]] || die "Config not found: ${config_file}\nUse 'cftunnel list' to see available tunnels."

  local hostname
  hostname=$(grep 'hostname:' "$config_file" | head -n1 | awk '{print $NF}')

  info "Starting tunnel: ${BOLD}${name}${NC}"
  [[ -n "$hostname" ]] && info "URL: ${BLUE}https://${hostname}${NC}"
  echo ""

  # Open browser after a short delay
  if [[ -n "$hostname" ]]; then
    (sleep 2 && open_url "https://${hostname}") &
  fi

  cloudflared tunnel --config "$config_file" run
}

cmd_run_interactive() {
  _load_tunnels || die "No tunnels configured.\nCreate one with: cftunnel create <name> <domain> <port>"

  local selected=0
  local total=${#_t_names[@]}

  # Disable strict mode for interactive input handling
  set +e

  tput civis 2>/dev/null

  while true; do
    printf '\033[H\033[J'

    echo -e "${BOLD}Select a tunnel${NC}  ${DIM}(↑/↓ navigate, enter select, q quit)${NC}"
    echo ""
    printf "    ${DIM}%-20s  %-35s  %-6s  %-36s${NC}\n" "NAME" "HOSTNAME" "PORT" "TUNNEL ID"
    echo ""

    for i in "${!_t_names[@]}"; do
      if [[ $i -eq $selected ]]; then
        _print_tunnel_row "${_t_names[$i]}" "${_t_hosts[$i]}" "${_t_ports[$i]}" "${_t_ids[$i]}" "  ${GREEN}❯${NC} " "active"
      else
        _print_tunnel_row "${_t_names[$i]}" "${_t_hosts[$i]}" "${_t_ports[$i]}" "${_t_ids[$i]}" "    " "dim"
      fi
    done

    IFS= read -rsn1 key || true

    case "$key" in
      $'\x1b')
        local seq=""
        read -rsn2 -t 1 seq || true
        case "$seq" in
          '[A') ((selected > 0)) && ((selected--)) ;;
          '[B') ((selected < total - 1)) && ((selected++)) ;;
        esac
        ;;
      k) ((selected > 0)) && ((selected--)) ;;
      j) ((selected < total - 1)) && ((selected++)) ;;
      '')
        tput cnorm 2>/dev/null
        set -e
        echo ""
        cmd_run "${_t_names[$selected]}"
        return
        ;;
      q|Q)
        tput cnorm 2>/dev/null
        set -e
        exit 0
        ;;
    esac
  done
}

# cftunnel list
cmd_list() {
  if ! _load_tunnels; then
    info "No tunnels configured."
    echo "  Create one with: cftunnel create <name> <domain> <port>"
    return
  fi

  echo -e "${BOLD}Configured tunnels:${NC}"
  echo ""
  printf "    ${DIM}%-20s  %-35s  %-6s  %-36s${NC}\n" "NAME" "HOSTNAME" "PORT" "TUNNEL ID"
  echo ""

  for i in "${!_t_names[@]}"; do
    _print_tunnel_row "${_t_names[$i]}" "${_t_hosts[$i]}" "${_t_ports[$i]}" "${_t_ids[$i]}" "    " "active"
  done
  echo ""
}

# cftunnel delete <name>
cmd_delete() {
  if [[ $# -lt 1 ]]; then
    echo -e "${BOLD}Usage:${NC} cftunnel delete <name>"
    exit 1
  fi

  local name="$1"
  local config_file="${CLOUDFLARED_DIR}/${name}.yml"

  [[ -f "$config_file" ]] || die "Config not found: ${config_file}"

  check_cloudflared

  local tid
  tid=$(grep '^tunnel:' "$config_file" | awk '{print $NF}')
  local cred_file="${CLOUDFLARED_DIR}/${tid}.json"

  echo -e "${YELLOW}You are about to delete tunnel '${name}'${NC}"
  [[ -n "$tid" ]] && echo -e "  Tunnel ID: ${DIM}${tid}${NC}"
  echo ""
  echo -ne "${RED}Confirm? (y/N): ${NC}"
  read -r confirm
  [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { echo "Cancelled."; exit 0; }

  # 1. Cleanup tunnel connections
  info "Cleaning up connections..."
  cloudflared tunnel cleanup "$name" 2>/dev/null || true

  # 2. Delete tunnel from Cloudflare
  info "Deleting tunnel..."
  if cloudflared tunnel delete "$name" 2>&1; then
    ok "Tunnel deleted from Cloudflare"
  else
    warn "Could not delete from Cloudflare (it may no longer exist)"
  fi

  # 3. Delete local files
  rm -f "$config_file"
  ok "Config deleted: ${config_file}"

  if [[ -f "$cred_file" ]]; then
    rm -f "$cred_file"
    ok "Credentials deleted: ${cred_file}"
  fi

  echo ""
  ok "Tunnel '${name}' fully deleted."
  echo ""
}

# cftunnel edit <name>
cmd_edit() {
  if [[ $# -lt 1 ]]; then
    echo -e "${BOLD}Usage:${NC} cftunnel edit <name>"
    exit 1
  fi

  local name="$1"
  local config_file="${CLOUDFLARED_DIR}/${name}.yml"

  [[ -f "$config_file" ]] || die "Config not found: ${config_file}"

  "${EDITOR:-nano}" "$config_file"
  ok "Configuration updated: ${config_file}"
}

# cftunnel port <name> <new-port>
cmd_port() {
  if [[ $# -lt 2 ]]; then
    echo -e "${BOLD}Usage:${NC} cftunnel port <name> <new-port>"
    echo ""
    echo -e "${DIM}Change the port of an existing tunnel.${NC}"
    exit 1
  fi

  local name="$1" new_port="$2"
  local config_file="${CLOUDFLARED_DIR}/${name}.yml"

  [[ -f "$config_file" ]] || die "Config not found: ${config_file}"

  # Replace port in config
  if sed -i.bak "s|service: http://localhost:[0-9]*|service: http://localhost:${new_port}|" "$config_file"; then
    rm -f "${config_file}.bak"
    ok "Port updated to ${new_port} for '${name}'"
  else
    die "Error updating port."
  fi
}

# cftunnel status
cmd_status() {
  check_cloudflared

  info "Tunnels registered in Cloudflare:"
  echo ""
  cloudflared tunnel list 2>&1
}

# -- Main ---------------------------------------------------------------------
cmd_help() {
  echo -e "${BOLD}cftunnel${NC} v${VERSION} - Manage Cloudflare Tunnels easily"
  echo ""
  echo -e "${BOLD}USAGE:${NC}"
  echo "  cftunnel <command> [arguments]"
  echo ""
  echo -e "${BOLD}COMMANDS:${NC}"
  printf "  ${GREEN}%-8s${NC} %-28s %s\n" "create" "<name> <domain> <port>" "Create tunnel + DNS route + config"
  printf "  ${GREEN}%-8s${NC} %-28s %s\n" "run"    "[name]"                  "Run tunnel (interactive if no name given)"
  printf "  ${GREEN}%-8s${NC} %-28s %s\n" "list"   ""                        "List configured tunnels"
  printf "  ${GREEN}%-8s${NC} %-28s %s\n" "delete" "<name>"                  "Delete tunnel and related files"
  printf "  ${GREEN}%-8s${NC} %-28s %s\n" "edit"   "<name>"                  "Edit tunnel YAML config"
  printf "  ${GREEN}%-8s${NC} %-28s %s\n" "port"   "<name> <port>"           "Change tunnel port"
  printf "  ${GREEN}%-8s${NC} %-28s %s\n" "status" ""                        "Show tunnels in Cloudflare"
  echo ""
  echo -e "${BOLD}EXAMPLES:${NC}"
  echo "  cftunnel create my-api example.com 3000"
  echo "  cftunnel run my-api"
  echo -e "  cftunnel run                  ${DIM}# interactive selector${NC}"
  echo "  cftunnel port my-api 8080"
  echo "  cftunnel list"
  echo "  cftunnel delete my-api"
  echo ""
  echo -e "${BOLD}ENVIRONMENT VARIABLES:${NC}"
  echo "  CLOUDFLARED_DIR   Config directory (default: ~/.cloudflared)"
  echo ""
  echo -e "${DIM}Requires: cloudflared (brew install cloudflared)${NC}"
}

cmd_version() {
  echo "cftunnel v${VERSION}"
}

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    create)   cmd_create "$@" ;;
    run|start) cmd_run "$@" ;;
    list|ls)  cmd_list ;;
    delete|rm) cmd_delete "$@" ;;
    edit)     cmd_edit "$@" ;;
    port)     cmd_port "$@" ;;
    status)   cmd_status ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) cmd_version ;;
    *)        err "Unknown command: ${cmd}"; echo ""; cmd_help; exit 1 ;;
  esac
}

main "$@"
